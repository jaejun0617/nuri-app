<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widgetRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/nuri_widget_surface"
    android:orientation="vertical"
    android:padding="16dp">

    <View
        android:id="@+id/widgetAccentBar"
        android:layout_width="56dp"
        android:layout_height="5dp"
        android:background="#6D6AF8" />

    <TextView
        android:id="@+id/widgetPetName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="우리 아이"
        android:textColor="#6D6AF8"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widgetSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="오늘을 바로 확인해요"
        android:textColor="#556070"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="오늘 일정"
            android:textColor="#0B1220"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetScheduleTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="오늘 일정이 없어요"
            android:textColor="#0B1220"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetScheduleMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="새 일정을 추가해 두면 위젯에서 바로 보여요"
            android:textColor="#556070"
            android:textSize="11sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="최근 기록"
            android:textColor="#0B1220"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetRecordTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="최근 기록이 아직 없어요"
            android:textColor="#0B1220"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widgetRecordMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="첫 기록을 남기면 최근 추억이 표시돼요"
            android:textColor="#556070"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
