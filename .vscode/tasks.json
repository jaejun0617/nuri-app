{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Codex: Start",
      "type": "shell",
      "command": "codex",
      "args": [
        "--no-alt-screen"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Codex: Resume Last",
      "type": "shell",
      "command": "codex",
      "args": [
        "resume",
        "--last",
        "--no-alt-screen"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
